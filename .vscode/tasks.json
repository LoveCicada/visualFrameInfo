{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake Build Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"default-debug-build"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "CMake Build Release",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"default-release-build"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Deploy Release Package",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/deploy_release.ps1"
			],
			"problemMatcher": []
		},
		{
			"label": "Build And Deploy Release",
			"dependsOn": [
				"CMake Build Release",
				"Deploy Release Package"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Package Inno Setup Installer",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/package_inno.ps1"
			],
			"problemMatcher": []
		},
		{
			"label": "Build Deploy And Package Installer",
			"dependsOn": [
				"Build And Deploy Release",
				"Package Inno Setup Installer"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Publish GitHub Release",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/publish_github_release.ps1"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Publish GitHub Release (Dry Run)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/publish_github_release.ps1",
				"-DryRun"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build Package And Publish Release",
			"dependsOn": [
				"Build Deploy And Package Installer",
				"Publish GitHub Release"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Build Package And Dry Run Publish",
			"dependsOn": [
				"Build Deploy And Package Installer",
				"Publish GitHub Release (Dry Run)"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Stage Release Workflow Updates",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".vscode/tasks.json",
				"README.md",
				"docs/release.md",
				"scripts/publish_github_release.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Commit Release Workflow Updates",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"docs: add v0.1.1 release upgrade guide and dry-run checks",
				"-m",
				"Document v0.1.1 version bump workflow in README and release guide.",
				"-m",
				"Add reusable dry-run release tasks and enhance publish script with -DryRun mode and gh path fallback."
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Push Release Workflow Updates",
			"type": "shell",
			"command": "git",
			"args": [
				"push",
				"origin",
				"master"
			],
			"isBackground": false,
			"problemMatcher": []
		}
	]
}