      "console": "integratedTerminal"
    },
    {
      "name": "Release CMake Target (MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/cmake-msvc-release/Release/visualFrameInfo.exe",
      "cwd": "${workspaceFolder}",
      "args": [],
      "stopAtEntry": false,
      "environment": [],
      "preLaunchTask": "CMake Build Release",
      "console": "integratedTerminal"
    }
  ]
}
